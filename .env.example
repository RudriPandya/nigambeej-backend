DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=nigam_beej_db

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

PORT=3001

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:3000

# Shared cookie domain when frontend and API use different subdomains (production).
# Hostinger previews: use the parent site, e.g. .hostingersite.com
# Custom domain: e.g. .nigambeej.com
# Omit locally; required for split-host preview/production unless API and app share one origin.
# COOKIE_DOMAIN=.hostingersite.com

# Node environment (development | production)
NODE_ENV=development

UPLOAD_DEST=./uploads

# Admin seed credentials (used by npm run migrate)
ADMIN_EMAIL=admin@nigambeej.com
ADMIN_PASS=CHANGE_ME_BEFORE_DEPLOY
ADMIN_NAME=Admin
