DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=nigam_beej_db

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

PORT=3001

# CORS Configuration (comma-separated list of allowed origins)
# Must include every frontend origin that calls the API (e.g. https://nigambeej.com).
CORS_ORIGIN=http://localhost:3000

# Cookie Domain for the API host’s parent (Set-Cookie comes from the API).
# Example API on Hostinger: COOKIE_DOMAIN=.hostingersite.com so the token is stored for *.hostingersite.com
# and sent on credentialed requests from https://nigambeej.com to your API URL (with SameSite=None).
# COOKIE_DOMAIN=.hostingersite.com

# Node environment (development | production)
NODE_ENV=development

UPLOAD_DEST=./uploads

# Admin seed credentials (used by npm run migrate)
ADMIN_EMAIL=admin@nigambeej.com
ADMIN_PASS=CHANGE_ME_BEFORE_DEPLOY
ADMIN_NAME=Admin
